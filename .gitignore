logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
bun-debug.log*

# Testing & coverage
coverage/
__screenshots__/
/cypress/videos/
/cypress/screenshots/

# TypeScript / tooling cache
*.tsbuildinfo
.eslintcache
*.timestamp-*-*.mjs

# Deploy platforms (may contain tokens or project IDs)
.vercel/
.netlify/
.firebase/
.surge/

# Docker local overrides
docker-compose.override.yml

# OS
.DS_Store
Thumbs.db
Desktop.ini

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Temporary files
tmp/
temp/
*.tmp
*.bak
*.swp
*~
